# 必填
TWITTER_USERNAME=
TWITTER_PASSWORD=

# 可选 - 验证
TWITTER_EMAIL=
TWITTER_PHONE=

# 可选 - 服务
MCP_PORT=18071
MCP_TRANSPORT=http          # http|sse|stdio
NODE_ENV=production         # development 显示浏览器

# 可选 - 代理
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# 可选 - 调试
SLOW_MO=0
AUTH_DIR=playwright/.auth
DEBUG_WEBHOOK_URL=
